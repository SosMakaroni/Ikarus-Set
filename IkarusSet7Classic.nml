		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               160 kW;
		weight:              14 ton;
		cargo_capacity:      141;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "livery/fullhalfhalf1", "power/diesel", "usage/city"];
		variant_group:             item_Ik280_d_CC1;
