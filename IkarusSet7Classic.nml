spriteset(ss_Ik180_a_BKV_purchase, "gfx/Old/Ik180_a.png")		{tmpl_purchase(1)}
spriteset(ss_Ik180_a_BKV_depo, "gfx/Old/Ik180_a.png")		{tmpl_depo(1)}

spriteset(ss_Ik180_a_BKV_a, "gfx/Old/Ik180_a.png")		{tmpl_1(1, 1, 0, 0)}
spriteset(ss_Ik180_a_BKV_a_loading, "gfx/Old/Ik180_a.png")		{tmpl_1(1, 1, 1, 0)}
spritegroup sg_Ik180_a_BKV_a {	loaded:  [ss_Ik180_a_BKV_a];	loading: [ss_Ik180_a_BKV_a_loading];}

spriteset(ss_Ik180_a_BKV_b, "gfx/Old/Ik180_a.png")		{tmpl_1(1, 2, 0, 0)}
spriteset(ss_Ik180_a_BKV_b_loading, "gfx/Old/Ik180_a.png")		{tmpl_1(1, 2, 1, 0)}
spritegroup sg_Ik180_a_BKV_b {	loaded:  [ss_Ik180_a_BKV_b];	loading: [ss_Ik180_a_BKV_b_loading];}

// Infóban, depóban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik180_a_BKV_depographic, position_in_consist ) {
	1: ss_toldat;
	ss_Ik180_a_BKV_depo;
}

// Játékban grafika
