// Item
item(FEAT_ROADVEHS, item_IkC80_a_CC2) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_C80), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1998,01,01);
		model_life:          30;
		vehicle_life:        40;
		reliability_decay:   20;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       40;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               90 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_2CC, ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               205 kW;
		weight:              14 ton;
		cargo_capacity:      118;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "livery/stripe1", "power/diesel", "usage/city"];
		variant_group:             item_IkC80_a_CC1;
	}
	graphics {
		default:             sw_IkC80_a_CC2;
		    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_IkC80_a_CC2_purchase;
		articulated_part:    sw_IkC80_a_CC2_articulated;
		length:              sw_IkC80_a_CC2_length;
		cost_factor:         24 * parapuco;
		running_cost_factor: 33 * pararuco;
		additional_text:     string(STR_GEN_DATA, string(STR_LOSPE_VFAST), 40, string(STR_COMFORT_4), 200, string(STR_O2_C80_40A), string(STR_O1_4_DOORS));
		name:                sw_IkC80_a_CC2_texts; // Vásárlási almenü switch
	}
}
// Csukló item
