		purchase:            ss_Ik260_e_Volan_purchase;
		articulated_part:    sw_Ik260_e_Volan_articulated;
		length:              sw_Ik260_e_Volan_length;
		cost_factor:         18 * parapuco;
		running_cost_factor: 25 * pararuco;
