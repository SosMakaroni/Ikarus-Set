// Item
item(FEAT_ROADVEHS, item_Ik280_f_CC5) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1980,01,01);
		model_life:          30;
		vehicle_life:        40;
		reliability_decay:   20;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       40;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               78 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_2CC, ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               160 kW;
		weight:              14 ton;
		cargo_capacity:      116;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "livery/dualbaseline2", "power/diesel", "usage/suburb"];
		variant_group:             item_Ik280_f_CC1;
	}
	graphics {
		default:             sw_Ik280_f_CC5;
		    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_Ik280_f_CC5_purchase;
		articulated_part:    sw_Ik280_f_CC5_articulated;
		length:              sw_Ik280_f_CC5_length;
		cost_factor:         21 * parapuco;
		running_cost_factor: 27 * pararuco;
		additional_text:     string(STR_GEN_DATA, string(STR_LOSPE_VFAST), 40, string(STR_COMFORT_4), 200, string(STR_O2_280_52), string(STR_O1_4_DOORS));
		name:                sw_Ik280_f_CC5_texts; // Vásárlási almenü switch
	}
}
// Csukló item
