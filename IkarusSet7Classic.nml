spriteset(ss_Ik260_g_BKV_purchase, "gfx/2xx/Ik260_g.png")		{tmpl_purchase(1)}
spriteset(ss_Ik260_g_BKV_depo, "gfx/2xx/Ik260_g.png")		{tmpl_depo(1)}

spriteset(ss_Ik260_g_BKV, "gfx/2xx/Ik260_g.png")		{tmpl_1(1, 1, 0, 1)}
spriteset(ss_Ik260_g_BKV_loading, "gfx/2xx/Ik260_g.png")		{tmpl_1(1, 1, 1, 1)}
spritegroup sg_Ik260_g_BKV {	loaded:  [ss_Ik260_g_BKV];	loading: [ss_Ik260_g_BKV_loading];}

// Infóban, depóban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_depographic, position_in_consist ) {
	1: ss_toldat;
	ss_Ik260_g_BKV_depo;
}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_gamegraphic, position_in_consist ) {
	1: sg_Ik260_g_BKV;
	ss_toldat;
}

// Grafika switch
switch (FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV, (extra_callback_info1 & 0x12) ) {
	0x10: sw_Ik260_g_BKV_depographic; // Depot GUI
	0x11: sw_Ik260_g_BKV_depographic; // Vehicle Details/Refit GUI
	0x12: sw_Ik260_g_BKV_depographic; // Vehicle List
	0x00: sw_Ik260_g_BKV_gamegraphic; // Vehicle in game
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_articulated, extra_callback_info1) {
	0: item_Ik260_g_BKV;
	1: item_Ik260_g_BKV_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_length, position_in_consist) {
	1: return 8;
    return 1;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_BKV)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik260_g_BKV_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_260), string(STR_O1_3_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik260_g_BKV_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_260), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

