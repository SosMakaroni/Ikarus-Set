		cost_factor:         23 * parapuco;
		running_cost_factor: 31 * pararuco;
		additional_text:     string(STR_GEN_DATA, string(STR_LOSPE_FAST), 36, string(STR_COMFORT_4), 200, string(STR_EMPTY), string(STR_O1_4_DOORS));
		name:                sw_Ik435_b_CC1_texts; // Vásárlási almenü switch
	}
}
