spritegroup sg_Ik284_a_BKV2_b {	loaded:  [ss_Ik284_a_BKV2_b];	loading: [ss_Ik284_a_BKV2_b_loading];}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik284_a_BKV2, position_in_consist ) {
	1: sg_Ik284_a_BKV2_a;
	2: sg_Ik284_a_BKV2_b;
	ss_toldat;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik284_a_BKV2_articulated, extra_callback_info1) {
	0: item_Ik284_a_BKV2;
	1: item_Ik284_a_BKV2_t;
	2: item_Ik284_a_BKV2_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik284_a_BKV2_length, position_in_consist) {
	1: return 8;
	2: return 7;
    return 2;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik284_a_BKV2_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_CC2)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik284_a_BKV2_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_284), string(STR_O1_4_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik284_a_BKV2_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_284), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

