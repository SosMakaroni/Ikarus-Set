// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik280_a_CC1, position_in_consist ) {
	1: sg_Ik280_a_CC1_a;
	2: sg_Ik280_a_CC1_b;
	ss_toldat;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik280_a_CC1_articulated, extra_callback_info1) {
	0: item_Ik280_a_CC1;
	1: item_Ik280_a_CC1_t;
	2: item_Ik280_a_CC1_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik280_a_CC1_length, position_in_consist) {
	1: return 8;
	2: return 6;
    return 1;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik280_a_CC1_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_CC1)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik280_a_CC1_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_O1_4_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik280_a_CC1_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

