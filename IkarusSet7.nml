// ---------- Ik435_a_BKV

/*még kellhet
		purchase:            ss_Ik435_a_BKV_a_purchase;
*/

spritegroup sg_Ik435_a_BKV_a {	loaded:  [ss_Ik435_a_BKV_a];	loading: [ss_Ik435_a_BKV_a_loading];}

spritegroup sg_Ik435_a_BKV_b {	loaded:  [ss_Ik435_a_BKV_b];	loading: [ss_Ik435_a_BKV_b_loading];}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik435_a_BKV, position_in_consist ) {
	1: sg_Ik435_a_BKV_a;
	2: sg_Ik435_a_BKV_b;
	ss_toldat;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik435_a_BKV_articulated, extra_callback_info1) {
	0: item_Ik435_a_BKV;
	1: item_Ik435_a_BKV_t;
	2: item_Ik435_a_BKV_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik435_a_BKV_length, position_in_consist) {
	1: return 8;
	2: return 7;
    return 2;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik435_a_BKV_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_BKV)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik435_a_BKV_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_435), string(STR_O1_4_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik435_a_BKV_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_435), string(STR_S1_PROTO), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

// Item
item(FEAT_ROADVEHS, item_Ik435_a_BKV) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_435), string(STR_S1_PROTO), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1985,01,01);
		model_life:          1;
		vehicle_life:        1;
		reliability_decay:   1;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       38;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               71 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               184 kW;
		weight:              15 ton;
		cargo_capacity:      177;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "power/diesel", "flag/HU", "usage/city"];
		variant_group:             item_Ik435_a_CC1;
	}
	graphics {
		default:             sw_Ik435_a_BKV;
		colour_mapping:	PALETTE_IDENTITY;    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_Ik435_a_BKV_a_purchase;
		articulated_part:    sw_Ik435_a_BKV_articulated;
		length:              sw_Ik435_a_BKV_length;
		cost_factor:         23 * parapuco;
		running_cost_factor: 30 * pararuco;
		additional_text:     string(STR_GEN_DATA, 38, string(STR_EMPTY), string(STR_EMPTY), string(STR_O1_4_DOORS));
		name:                sw_Ik435_a_BKV_texts; // Vásárlási almenü switch
	}
}
// Csukló item
item(FEAT_ROADVEHS, item_Ik435_a_BKV_t) {
	property {
		name:							string(STR_BUG);
		climates_available:			bitmask(NO_CLIMATE);
		introduction_date:				date(4999999,01,01);
		cargo_allow_refit:				[PASS,TOUR];
		loading_speed:					0;
		cost_factor:					0;
		running_cost_factor:			0;
		sprite_id:						SPRITE_ID_NEW_ROADVEH;
		misc_flags:					bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:					0;
		running_cost_base:				RUNNING_COST_NONE;
		power:							0 kW;
		weight:						0 ton;
		cargo_capacity:				0;
		cargo_age_period:				0;
	}
	graphics {
		default:						sw_Ik435_a_BKV;
		colour_mapping:	PALETTE_IDENTITY; // Cégszín deaktiválás, ha valós színű jármű
		length:						sw_Ik435_a_BKV_length;
	}
}
