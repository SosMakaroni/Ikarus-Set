*/

spritegroup sg_Ik415_c_Volan {	loaded:  [ss_Ik415_c_Volan];	loading: [ss_Ik415_c_Volan_loading];}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik415_c_Volan, position_in_consist ) {
	1: sg_Ik415_c_Volan;
	ss_toldat;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik415_c_Volan_articulated, extra_callback_info1) {
	0: item_Ik415_c_Volan;
	1: item_Ik415_c_Volan_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik415_c_Volan_length, position_in_consist) {
	1: return 8;
    return 3;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik415_c_Volan_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_VOLAN)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik415_c_Volan_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_415), string(STR_O1_2_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik415_c_Volan_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_415), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

// Item
item(FEAT_ROADVEHS, item_Ik415_c_Volan) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_415), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1992,01,01);
		model_life:          1;
		vehicle_life:        1;
		reliability_decay:   1;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       20;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               92 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               184 kW;
		weight:              12 ton;
		cargo_capacity:      78;
		cargo_age_period:    185;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "power/diesel", "flag/HU", "usage/regional"];
		variant_group:             item_Ik415_c_CC1;
	}
	graphics {
		default:             sw_Ik415_c_Volan;
		colour_mapping:	PALETTE_IDENTITY;    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_Ik415_c_Volan_purchase;
		articulated_part:    sw_Ik415_c_Volan_articulated;
		length:              sw_Ik415_c_Volan_length;
		cost_factor:         20 * parapuco;
		running_cost_factor: 28 * pararuco;
		additional_text:     string(STR_GEN_DATA, 20, string(STR_EMPTY), string(STR_EMPTY), string(STR_O1_2_DOORS));
		name:                sw_Ik415_c_Volan_texts; // Vásárlási almenü switch
	}
}
// Csukló item
item(FEAT_ROADVEHS, item_Ik415_c_Volan_t) {
	property {
		name:							string(STR_BUG);
		climates_available:			bitmask(NO_CLIMATE);
		introduction_date:				date(4999999,01,01);
		cargo_allow_refit:				[PASS,TOUR];
		loading_speed:					0;
