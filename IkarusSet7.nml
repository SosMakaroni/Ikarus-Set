// ---------- Ik622_b_BKV

/*még kellhet
		purchase:            ss_Ik622_b_BKV_a_purchase;
*/

spritegroup sg_Ik622_b_BKV_a {	loaded:  [ss_Ik622_b_BKV_a];	loading: [ss_Ik622_b_BKV_a_loading];}

spritegroup sg_Ik622_b_BKV_b {	loaded:  [ss_Ik622_b_BKV_b];	loading: [ss_Ik622_b_BKV_b_loading];}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik622_b_BKV, position_in_consist ) {
	1: sg_Ik622_b_BKV_b;
	sg_Ik622_b_BKV_a;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik622_b_BKV_articulated, extra_callback_info1) {
	0: item_Ik622_b_BKV;
	1: item_Ik622_b_BKV_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik622_b_BKV_length, position_in_consist) {
	1: return 6;
    return 8;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik622_b_BKV_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_BKV)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik622_b_BKV_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_622), string(STR_O1_3_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik622_b_BKV_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_622), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

