// ----------------------badges:
template tmpl_badge_1812(x, y) {
	[x,	y,	18,	12,	0,	0]}
template tmpl_badge_1512(x, y) {
	[x,	y,	15,	12,	0,	0]}
template tmpl_badge_1310(x, y) {
	[x,	y,	13,	10,	0,	0]}
template tmpl_badge_1010(x, y) {
	[x,	y,	10,	10,	0,	0]}
template tmpl_badge_1112(x, y) {
	[x,	y,	11,	12,	0,	0]}
template tmpl_badge_1110(x, y) {
	[x,	y,	11,	10,	0,	0]}
// ---type
spriteset(ss_type_tram, "gfx/icons.png")		{tmpl_badge_1110(20, 180)}
spriteset(ss_type_bus, "gfx/icons.png")		{tmpl_badge_1110(40, 180)}
spriteset(ss_type_truck, "gfx/icons.png")		{tmpl_badge_1110(60, 180)}

item (FEAT_BADGES, type) {
    property {
        label: "type";
    }
}

item (FEAT_BADGES, type_tram) {
    property {
        label: "type/tram";
    }
	graphics {
		default: ss_type_tram;
	}
}
item (FEAT_BADGES, type_bus) {
    property {
        label: "type/bus";
    }
	graphics {
		default: ss_type_bus;
	}
}
item (FEAT_BADGES, type_truck) {
    property {
        label: "type/truck";
    }
	graphics {
		default: ss_type_truck;
	}
}
// ---power
spriteset (ss_power_battery, "gfx/icons.png")		{tmpl_badge_1310(180, 100)}
spriteset (ss_power_diesel, "gfx/icons.png")		{tmpl_badge_1310(140, 100)}
spriteset (ss_power_electric, "gfx/icons.png")	{tmpl_badge_1310(40, 100)}
spriteset (ss_power_naturgas, "gfx/icons.png")	{tmpl_badge_1010(20, 100)}
spriteset (ss_power_eldiesel, "gfx/icons.png")	{tmpl_badge_1310(80, 100)}
spriteset (ss_power_hydrogen, "gfx/icons.png")	{tmpl_badge_1010(60, 100)}
spriteset (ss_power_petrol, "gfx/icons.png")		{tmpl_badge_1310(160, 100)}


item (FEAT_BADGES, power) {
    property {
        label: "power";
        name: string(STR_POWER);
    }
}

item (FEAT_BADGES, power_battery) {
    property {
        label: "power/battery";
        name: string(STR_BATTERY);
	}
	graphics {
		default: ss_power_battery;
	}
}

	
item (FEAT_BADGES, power_diesel) {
    property {
        label: "power/diesel";
        name: string(STR_DIESEL);
	}
	graphics {
		default: ss_power_diesel;
	}
}

item (FEAT_BADGES, power_electric) {
    property {
        label: "power/electric";
        name: string(STR_ELECTRIC);
	}
	graphics {
		default: ss_power_electric;
	}
}

item (FEAT_BADGES, power_naturgas) {
    property {
        label: "power/naturgas";
        name: string(STR_NATURGAS);
    }
	graphics {
		default: ss_power_naturgas;
	}
}

item (FEAT_BADGES, power_eldiesel) {
    property {
        label: "power/eldiesel";
        name: string(STR_ELDIESEL);
    }
	graphics {
		default: ss_power_eldiesel;
	}
}

item (FEAT_BADGES, power_hydrogen) {
    property {
        label: "power/hydrogen";
        name: string(STR_HYDROGEN);
    }
	graphics {
		default: ss_power_hydrogen;
	}
}

item (FEAT_BADGES, power_petrol) {
    property {
        label: "power/petrol";
        name: string(STR_PETROL);
    }
	graphics {
		default: ss_power_petrol;
	}
}
// ---Usage
spriteset(ss_usage_city, "gfx/icons.png")		{tmpl_badge_1512(20, 120)}
spriteset(ss_usage_suburb, "gfx/icons.png")		{tmpl_badge_1512(40, 120)}
spriteset(ss_usage_regional, "gfx/icons.png")		{tmpl_badge_1512(60, 120)}
spriteset(ss_usage_intercity, "gfx/icons.png")		{tmpl_badge_1512(80, 120)}
spriteset(ss_usage_tourist, "gfx/icons.png")		{tmpl_badge_1512(100, 120)}

item (FEAT_BADGES, usage) {
    property {
        label: "usage";
        name: string(STR_USAGE);
    }
}
item (FEAT_BADGES, city) {
    property {
        label: "usage/city";
        name: string(STR_USAGE_CITY);
    }
	graphics {
		default: ss_usage_city;
	}
}
item (FEAT_BADGES, suburb) {
    property {
        label: "usage/suburb";
        name: string(STR_USAGE_SUBURB);
    }
	graphics {
		default: ss_usage_suburb;
	}
}
item (FEAT_BADGES, regional) {
    property {
        label: "usage/regional";
        name: string(STR_USAGE_REGIONAL);
    }
	graphics {
		default: ss_usage_regional;
	}
}
item (FEAT_BADGES, intercity) {
    property {
        label: "usage/intercity";
        name: string(STR_USAGE_INTERCITY);
    }
	graphics {
		default: ss_usage_intercity;
	}
}
item (FEAT_BADGES, tourist) {
    property {
        label: "usage/tourist";
        name: string(STR_USAGE_TOURIST);
    }
	graphics {
		default: ss_usage_tourist;
	}
}
// ---flag
spriteset(ss_flag_CC, "gfx/icons.png")		{tmpl_badge_1812(140, 80)}

item (FEAT_BADGES, flag) {
    property {
        label: "flag";
        name: string(STR_FLAG);
        flags: bitmask(BADGE_FLAG_COPY_TO_RELATED_ENTITY);
    }
}

item (FEAT_BADGES, flag_CC) {
    property {
        label: "flag/flag_CC";
        name: string(STR_2CC);
        flags: bitmask(BADGE_FLAG_COPY_TO_RELATED_ENTITY, BADGE_FLAG_USE_COMPANY_COLOUR);
    }
	graphics {
		default: ss_flag_CC;
	}
}
