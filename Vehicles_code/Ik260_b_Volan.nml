// ---------- Ik260_b_Volan


spriteset(ss_Ik260_b_Volan_purchase, "gfx/2xx/Ik260_b.png")		{tmpl_purchase(7)}
spriteset(ss_Ik260_b_Volan_depo, "gfx/2xx/Ik260_b.png")		{tmpl_depo(7)}

spriteset(ss_Ik260_b_Volan, "gfx/2xx/Ik260_b.png")		{tmpl_1(7, 1, 0, 1)}
spriteset(ss_Ik260_b_Volan_loading, "gfx/2xx/Ik260_b.png")		{tmpl_1(7, 1, 1, 1)}
spritegroup sg_Ik260_b_Volan {	loaded:  [ss_Ik260_b_Volan];	loading: [ss_Ik260_b_Volan_loading];}

// Infóban, depóban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_depographic, position_in_consist ) {
	1: ss_toldat;
	ss_Ik260_b_Volan_depo;
}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_gamegraphic, position_in_consist ) {
	1: sg_Ik260_b_Volan;
	ss_toldat;
}

// Grafika switch
switch (FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan, (extra_callback_info1 & 0x12) ) {
	0x10: sw_Ik260_b_Volan_depographic; // Depot GUI
	0x11: sw_Ik260_b_Volan_depographic; // Vehicle Details/Refit GUI
	0x12: sw_Ik260_b_Volan_depographic; // Vehicle List
	0x00: sw_Ik260_b_Volan_gamegraphic; // Vehicle in game
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_articulated, extra_callback_info1) {
	0: item_Ik260_b_Volan;
	1: item_Ik260_b_Volan_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_length, position_in_consist) {
	1: return 8;
    return 1;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_VOLAN)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik260_b_Volan_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_260), string(STR_O1_2_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik260_b_Volan_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_260), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

// Item
item(FEAT_ROADVEHS, item_Ik260_b_Volan) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_260), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1971,01,01);
		model_life:          30;
		vehicle_life:        40;
		reliability_decay:   20;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       20;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               78 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               141 kW;
		weight:              11 ton;
		cargo_capacity:      71;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "livery/hungarian", "power/diesel", "usage/suburb"];
		variant_group:             item_Ik260_b_CC1;
	}
	graphics {
		default:             sw_Ik260_b_Volan;
		colour_mapping:	PALETTE_IDENTITY;    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_Ik260_b_Volan_purchase;
		articulated_part:    sw_Ik260_b_Volan_articulated;
		length:              sw_Ik260_b_Volan_length;
		cost_factor:         17 * parapuco;
		running_cost_factor: 22 * pararuco;
		additional_text:     string(STR_GEN_DATA, string(STR_LOSPE_VFAST), 20, string(STR_COMFORT_4), 200, string(STR_O2_260_31), string(STR_O1_2_DOORS));
		name:                sw_Ik260_b_Volan_texts; // Vásárlási almenü switch
	}
}
// Csukló item
item(FEAT_ROADVEHS, item_Ik260_b_Volan_t) {
	property {
		name:							string(STR_BUG);
		climates_available:			bitmask(NO_CLIMATE);
		introduction_date:				date(4999999,01,01);
		cargo_allow_refit:				[PASS,TOUR];
		loading_speed:					0;
		cost_factor:					0;
		running_cost_factor:			0;
		sprite_id:						SPRITE_ID_NEW_ROADVEH;
		misc_flags:					bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:					0;
		running_cost_base:				RUNNING_COST_NONE;
		power:							0 kW;
		weight:						0 ton;
		cargo_capacity:				0;
		cargo_age_period:				0;
	}
	graphics {
		default:						sw_Ik260_b_Volan;
		colour_mapping:	PALETTE_IDENTITY; // Cégszín deaktiválás, ha valós színű jármű
		length:						sw_Ik260_b_Volan_length;
	}
}
// ---------- Ik260_b_Volan --- End

