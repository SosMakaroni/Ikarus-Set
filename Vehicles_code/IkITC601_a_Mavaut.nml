// ---------- IkITC601_a_Mavaut

/*még kellhet
		purchase:            ss_IkITC601_a_Mavaut_a_purchase;
*/

spritegroup sg_IkITC601_a_Mavaut_a {	loaded:  [ss_IkITC601_a_Mavaut_a];	loading: [ss_IkITC601_a_Mavaut_a_loading];}

spritegroup sg_IkITC601_a_Mavaut_b {	loaded:  [ss_IkITC601_a_Mavaut_b];	loading: [ss_IkITC601_a_Mavaut_b_loading];}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_IkITC601_a_Mavaut, position_in_consist ) {
	1: sg_IkITC601_a_Mavaut_b;
	sg_IkITC601_a_Mavaut_a;
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_IkITC601_a_Mavaut_articulated, extra_callback_info1) {
	0: item_IkITC601_a_Mavaut;
	1: item_IkITC601_a_Mavaut_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_IkITC601_a_Mavaut_length, position_in_consist) {
	1: return 6;
    return 8;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_IkITC601_a_Mavaut_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_MAVAUT)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_IkITC601_a_Mavaut_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_ITC601), string(STR_O1_2_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_IkITC601_a_Mavaut_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_ITC601), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

// Item
item(FEAT_ROADVEHS, item_IkITC601_a_Mavaut) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_ITC601), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1960,01,01);
		model_life:          1;
		vehicle_life:        1;
		reliability_decay:   1;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       16;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               55 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               91 kW;
		weight:              11 ton;
		cargo_capacity:      128;
		cargo_age_period:    185;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "power/diesel", "flag/HU", "usage/regional"];
		variant_group:             item_IkITC601_a_CC1;
	}
	graphics {
		default:             sw_IkITC601_a_Mavaut;
		colour_mapping:	PALETTE_IDENTITY;    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_IkITC601_a_Mavaut_a_purchase;
		articulated_part:    sw_IkITC601_a_Mavaut_articulated;
		length:              sw_IkITC601_a_Mavaut_length;
		cost_factor:         13 * parapuco;
		running_cost_factor: 15 * pararuco;
		additional_text:     string(STR_GEN_DATA, 16, string(STR_EMPTY), string(STR_EMPTY), string(STR_O1_2_DOORS));
		name:                sw_IkITC601_a_Mavaut_texts; // Vásárlási almenü switch
	}
}
// Csukló item
item(FEAT_ROADVEHS, item_IkITC601_a_Mavaut_t) {
	property {
		name:							string(STR_BUG);
		climates_available:			bitmask(NO_CLIMATE);
		introduction_date:				date(4999999,01,01);
		cargo_allow_refit:				[PASS,TOUR];
		loading_speed:					0;
		cost_factor:					0;
		running_cost_factor:			0;
		sprite_id:						SPRITE_ID_NEW_ROADVEH;
		misc_flags:					bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:					0;
		running_cost_base:				RUNNING_COST_NONE;
		power:							0 kW;
		weight:						0 ton;
		cargo_capacity:				0;
		cargo_age_period:				0;
	}
	graphics {
		default:						sw_IkITC601_a_Mavaut;
		colour_mapping:	PALETTE_IDENTITY; // Cégszín deaktiválás, ha valós színű jármű
		length:						sw_IkITC601_a_Mavaut_length;
	}
}
// ---------- IkITC601_a_Mavaut --- End

