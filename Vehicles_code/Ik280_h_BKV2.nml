// ---------- Ik280_h_BKV2


spriteset(ss_Ik280_h_BKV2_purchase, "gfx/2xx/Ik280_h.png")		{tmpl_purchase(3)}
spriteset(ss_Ik280_h_BKV2_depo, "gfx/2xx/Ik280_h.png")		{tmpl_depo(3)}

spriteset(ss_Ik280_h_BKV2_a, "gfx/2xx/Ik280_h.png")		{tmpl_1(3, 1, 0, 0)}
spriteset(ss_Ik280_h_BKV2_a_loading, "gfx/2xx/Ik280_h.png")		{tmpl_1(3, 1, 1, 0)}
spritegroup sg_Ik280_h_BKV2_a {	loaded:  [ss_Ik280_h_BKV2_a];	loading: [ss_Ik280_h_BKV2_a_loading];}

spriteset(ss_Ik280_h_BKV2_b, "gfx/2xx/Ik280_h.png")		{tmpl_1(3, 2, 0, 0)}
spriteset(ss_Ik280_h_BKV2_b_loading, "gfx/2xx/Ik280_h.png")		{tmpl_1(3, 2, 1, 0)}
spritegroup sg_Ik280_h_BKV2_b {	loaded:  [ss_Ik280_h_BKV2_b];	loading: [ss_Ik280_h_BKV2_b_loading];}

// Infóban, depóban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_depographic, position_in_consist ) {
	1: ss_toldat;
	ss_Ik280_h_BKV2_depo;
}

// Játékban grafika
switch (FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_gamegraphic, position_in_consist ) {
	1: sg_Ik280_h_BKV2_b;
	sg_Ik280_h_BKV2_a;
}

// Grafika switch
switch (FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2, (extra_callback_info1 & 0x12) ) {
	0x10: sw_Ik280_h_BKV2_depographic; // Depot GUI
	0x11: sw_Ik280_h_BKV2_depographic; // Vehicle Details/Refit GUI
	0x12: sw_Ik280_h_BKV2_depographic; // Vehicle List
	0x00: sw_Ik280_h_BKV2_gamegraphic; // Vehicle in game
}

// Csuklosítás
switch (FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_articulated, extra_callback_info1) {
	0: item_Ik280_h_BKV2;
	1: item_Ik280_h_BKV2_t;
	CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// Modelhossz
switch (FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_length, position_in_consist) {
	1: return 7;
    return 8;
}

// Szövegek
switch(FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_names, (extra_callback_info1 >> 8) & 0xFFFF) {
	1: return string(STR_GEN_LIVERY, string(STR_LIV_BKV)); // Almenü 1 név
	return CB_RESULT_NO_TEXT;
}

switch(FEAT_ROADVEHS, SELF, sw_Ik280_h_BKV2_texts, extra_callback_info1 & 0xFF) {
	0x11: return string(STR_GEN_INFO, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_O1_4_DOORS)); // Jármű infóban név (Gyártó-Típus-Ajtó)
	0x20: sw_Ik280_h_BKV2_names; // Vásárlási lista név
	0x21: return string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_EMPTY), string(STR_EMPTY)); // Elővásárlási név
	return CB_RESULT_NO_TEXT;
}

// Item
item(FEAT_ROADVEHS, item_Ik280_h_BKV2) {
	property {
		name:                string(STR_GEN_NAME, string(STR_MFR_IKARUS), string(STR_T1_280), string(STR_EMPTY), string(STR_EMPTY));
		climates_available:  bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL);
		introduction_date:   date(1998,01,01);
		model_life:          30;
		vehicle_life:        40;
		reliability_decay:   20;
		cargo_allow_refit:   [PASS,TOUR];
		loading_speed:       40;
		sprite_id:           SPRITE_ID_NEW_ROADVEH;
		speed:               72 km/h;
		misc_flags:          bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:          0;
		running_cost_base:   RUNNING_COST_ROADVEH;
		power:               190 kW;
		weight:              14 ton;
		cargo_capacity:      146;
		cargo_age_period:    200;
		sound_effect:        SOUND_DEPARTURE_MODERN_BUS;
		badges:              ["type/bus", "livery/hungarian", "power/diesel", "usage/city"];
		variant_group:             item_Ik280_h_CC1;
	}
	graphics {
		default:             sw_Ik280_h_BKV2;
		colour_mapping:	PALETTE_IDENTITY;    // Cégszín deaktiválás, ha valós színű jármű
		purchase:            ss_Ik280_h_BKV2_purchase;
		articulated_part:    sw_Ik280_h_BKV2_articulated;
		length:              sw_Ik280_h_BKV2_length;
		cost_factor:         23 * parapuco;
		running_cost_factor: 31 * pararuco;
		additional_text:     string(STR_GEN_DATA, string(STR_LOSPE_VFAST), 40, string(STR_COMFORT_4), 200, string(STR_O2_280_40A), string(STR_O1_4_DOORS));
		name:                sw_Ik280_h_BKV2_texts; // Vásárlási almenü switch
	}
}
// Csukló item
item(FEAT_ROADVEHS, item_Ik280_h_BKV2_t) {
	property {
		name:							string(STR_BUG);
		climates_available:			bitmask(NO_CLIMATE);
		introduction_date:				date(4999999,01,01);
		cargo_allow_refit:				[PASS,TOUR];
		loading_speed:					0;
		cost_factor:					0;
		running_cost_factor:			0;
		sprite_id:						SPRITE_ID_NEW_ROADVEH;
		misc_flags:					bitmask(ROADVEH_FLAG_SPRITE_STACK);
		refit_cost:					0;
		running_cost_base:				RUNNING_COST_NONE;
		power:							0 kW;
		weight:						0 ton;
		cargo_capacity:				0;
		cargo_age_period:				0;
	}
	graphics {
		default:						sw_Ik280_h_BKV2;
		colour_mapping:	PALETTE_IDENTITY; // Cégszín deaktiválás, ha valós színű jármű
		length:						sw_Ik280_h_BKV2_length;
	}
}
// ---------- Ik280_h_BKV2 --- End

